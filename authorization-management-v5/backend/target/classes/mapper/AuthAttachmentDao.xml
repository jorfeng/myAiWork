<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.auth.letter.dao.AuthAttachmentDao">

    <resultMap id="BaseResultMap" type="com.auth.letter.entity.AuthAttachment">
        <id column="id" property="id"/>
        <result column="letter_id" property="letterId"/>
        <result column="doc_name" property="docName"/>
        <result column="doc_type" property="docType"/>
        <result column="doc_id" property="docId"/>
        <result column="is_encrypted" property="isEncrypted"/>
        <result column="created_by" property="createdBy"/>
        <result column="created_time" property="createdTime"/>
        <result column="updated_by" property="updatedBy"/>
        <result column="updated_time" property="updatedTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, letter_id, doc_name, doc_type, doc_id, is_encrypted,
        created_by, created_time, updated_by, updated_time
    </sql>

    <select id="selectByLetterId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM auth_attachment
        WHERE letter_id = #{letterId}
        ORDER BY created_time DESC
        LIMIT #{pageSize} OFFSET #{offset}
    </select>

    <select id="countByLetterId" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM auth_attachment
        WHERE letter_id = #{letterId}
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM auth_attachment
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.auth.letter.entity.AuthAttachment" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO auth_attachment (
            letter_id, doc_name, doc_type, doc_id, is_encrypted,
            created_by, created_time, updated_by, updated_time
        ) VALUES (
            #{letterId}, #{docName}, #{docType}, #{docId}, #{isEncrypted},
            #{createdBy}, #{createdTime}, #{updatedBy}, #{updatedTime}
        )
    </insert>

    <delete id="deleteById">
        DELETE FROM auth_attachment WHERE id = #{id}
    </delete>

    <delete id="deleteByIds">
        DELETE FROM auth_attachment
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>