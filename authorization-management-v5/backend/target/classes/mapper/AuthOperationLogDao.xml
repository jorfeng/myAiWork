<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.auth.letter.dao.AuthOperationLogDao">

    <resultMap id="BaseResultMap" type="com.auth.letter.entity.AuthOperationLog">
        <id column="id" property="id"/>
        <result column="letter_id" property="letterId"/>
        <result column="operation" property="operation"/>
        <result column="operator" property="operator"/>
        <result column="operation_time" property="operationTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, letter_id, operation, operator, operation_time
    </sql>

    <select id="selectByLetterId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM auth_operation_log
        WHERE letter_id = #{letterId}
        ORDER BY operation_time DESC
        LIMIT #{pageSize} OFFSET #{offset}
    </select>

    <select id="countByLetterId" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM auth_operation_log
        WHERE letter_id = #{letterId}
    </select>

    <insert id="insert" parameterType="com.auth.letter.entity.AuthOperationLog" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO auth_operation_log (
            letter_id, operation, operator, operation_time
        ) VALUES (
            #{letterId}, #{operation}, #{operator}, #{operationTime}
        )
    </insert>

</mapper>